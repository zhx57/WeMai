# WeMai 环境变量示例文件
# 复制此文件为 .env 并根据需要修改配置

# 微信监听配置
# 要监听的聊天对象列表，多个用逗号分隔
WX_TARGET_CHATS=test1,test2
# 需要可靠指定类型时可使用 JSON：
# WX_TARGET_CHATS=[{"name":"项目群","type":"group"},{"name":"张总","type":"private"}]

# 是否在未指定目标聊天时监听所有聊天 (true/false)
WX_LISTEN_ALL_IF_EMPTY=false

# 排除的聊天对象，多个用逗号分隔
WX_EXCLUDED_CHATS=文件传输助手,微信团队,微信支付

# MaiBot API 配置
# 新版麦麦(>=1.0)用 maim_message 库的纯 WebSocket 服务。
# 地址对应 MaiBot 的 config/bot_config.toml 里 [maim_message] 段：
#   ws_server_host (默认 127.0.0.1) 和 ws_server_port (默认 8000)。
# 本机部署就用 ws://127.0.0.1:8000/ws；远程部署把 127.0.0.1 换成麦麦服务器 IP。
# 注意：端口必须是 ws_server_port（默认 8000），不是 WebUI 端口（默认 8001）。
MAIBOT_API_URL=ws://127.0.0.1:8000/ws

# 日志配置
# 可选值: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_FILE=wepush.log
LOG_FORMAT=%(asctime)s - %(levelname)s - %(message)s
LOG_DATE_FORMAT=%Y-%m-%d %H:%M:%S

# 平台标识,如果修改了，请调整maibot中的bot_config.toml中的消息推送平台
PLATFORM_ID=wxauto

# 机器人自己的微信昵称（可选）
# 用于排除把机器人自己当接收者的情况。建议填，多一层保险。
WX_BOT_NICKNAME=麦麦

# 图片下载配置
# 是否启用自动下载图片 (true/false)
IMAGE_AUTO_DOWNLOAD=true

# 图片识别配置
# 是否启用图像识别功能 (true/false)
IMAGE_RECOGNITION_ENABLED=true

# 队列、媒体和状态文件限制
SEND_QUEUE_SIZE=100
UI_QUEUE_SIZE=100
MAX_MEDIA_BYTES=10485760
MEDIA_DOWNLOAD_TIMEOUT_SECONDS=15
MEDIA_DOWNLOAD_MAX_REDIRECTS=3
ID_MAP_FILE=wemai_id_map.json
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
